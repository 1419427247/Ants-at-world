[sub_resource type="GDScript" id="GDScript_camera_controller"]
script/source = "extends Node

@onready var gi_element: GIElement = $GIElement


func _process(delta: float) -> void:
	gi_element.global_position = gi_element.get_global_mouse_position()
"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_ikwhx"]
shader = ExtResource("1_3klt6")
shader_parameter/dirt_color = Color(0.42, 0.28, 0.15, 1)
shader_parameter/dark_color = Color(0.3, 0.18, 0.08, 1)
shader_parameter/light_color = Color(0.55, 0.38, 0.22, 1)
shader_parameter/noise_scale = 6.3950002800125
shader_parameter/roughness = 0.6
shader_parameter/pebble_amount = 0.082000003895

[sub_resource type="ShaderMaterial" id="ShaderMaterial_composite"]
shader = ExtResource("6_srgb")
shader_parameter/indirect_strength = 1.0
shader_parameter/ao_strength = 1.0
shader_parameter/dir_color = Color(1, 1, 1, 0.003921569)
shader_parameter/shadow_color = Color(0, 0, 0, 0.043137256)

[sub_resource type="GDScript" id="GDScript_composite"]
script/source = "extends ColorRect

@export var pass_gi: ComputePass
@export var pass_directional: ComputePass
@export var pass_ao: ComputePass

func _process(delta: float) -> void:
	var gi_texture := Texture2DRD.new()
	gi_texture.texture_rd_rid = pass_gi.get_output_resource_id()
	material.set_shader_parameter(\"gi_texture\", gi_texture)

	var dir_tex := Texture2DRD.new()
	dir_tex.texture_rd_rid = pass_directional.get_output_resource_id()
	material.set_shader_parameter(\"directional_texture\", dir_tex)

	var ao_tex := Texture2DRD.new()
	ao_tex.texture_rd_rid = pass_ao.get_output_resource_id()
	material.set_shader_parameter(\"ao_texture\", ao_tex)
"

